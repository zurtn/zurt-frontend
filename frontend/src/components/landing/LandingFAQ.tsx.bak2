} from "@/components/ui/accordion";

const faqs = [
  {
    question: "O ZURT acessa minha senha bancária?",
    answer: "Nunca. O ZURT utiliza Open Finance regulamentado pelo Banco Central do Brasil. A autorização é feita diretamente no aplicativo do seu banco, com acesso somente-leitura. Nunca movimentamos valores.",
