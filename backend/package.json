{
  "name": "zurt-backend",
  "version": "1.0.0",
  "description": "Backend API for zurT financial consolidation platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:schema": "psql $DATABASE_URL -f schema.sql",
    "db:migrate": "tsx src/db/run-migration.ts",
    "db:migrate:full": "tsx src/db/execute-schema.ts",
    "db:update-plans": "tsx src/db/update-plans.ts",
    "db:test": "tsx src/db/test-connection.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-institutions": "tsx src/db/seed-institutions.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "fintech",
    "open-finance",
    "financial-consolidation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^7.0.0",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.0.0",
    "fastify": "^5.8.4",
    "mercadopago": "^2.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.15.2",
    "pg": "^8.18.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
